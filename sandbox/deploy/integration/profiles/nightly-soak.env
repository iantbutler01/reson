# @dive-file: Profile template for long-running nightly soak integration runs.
# @dive-rel: Loaded by scripts/integration/common.sh when --profile nightly-soak is selected.
# @dive-rel: Provides isolated compose project and ports for soak-specific artifact collection.
CHEVALIER_SANDBOX_INTEGRATION_PROFILE=nightly-soak
CHEVALIER_SANDBOX_INTEGRATION_PROJECT=chevalier-sandbox-int-nightly-soak
CHEVALIER_SANDBOX_INTEGRATION_COMPOSE_FILE=deploy/integration/docker-compose.control-plane.yml
CHEVALIER_SANDBOX_INTEGRATION_CLUSTER_TOKEN=chevalier-sandbox-int-nightly-soak
CHEVALIER_SANDBOX_INTEGRATION_ETCD_PORT=52379
CHEVALIER_SANDBOX_INTEGRATION_NATS_PORT=34222
CHEVALIER_SANDBOX_INTEGRATION_NATS_MONITOR_PORT=38222
CHEVALIER_SANDBOX_INTEGRATION_ETCD_ENDPOINTS=http://127.0.0.1:52379
CHEVALIER_SANDBOX_INTEGRATION_NATS_URL=nats://127.0.0.1:34222
CHEVALIER_SANDBOX_INTEGRATION_ARTIFACT_DIR=.integration-artifacts/nightly-soak
