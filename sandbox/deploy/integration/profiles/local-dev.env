# @dive-file: Profile template for local developer real integration harness runs.
# @dive-rel: Loaded by scripts/integration/common.sh when --profile local-dev is selected.
# @dive-rel: Targets deploy/integration/docker-compose.control-plane.yml with local host port mappings.
CHEVALIER_SANDBOX_INTEGRATION_PROFILE=local-dev
CHEVALIER_SANDBOX_INTEGRATION_PROJECT=chevalier-sandbox-int-local-dev
CHEVALIER_SANDBOX_INTEGRATION_COMPOSE_FILE=deploy/integration/docker-compose.control-plane.yml
CHEVALIER_SANDBOX_INTEGRATION_CLUSTER_TOKEN=chevalier-sandbox-int-local
CHEVALIER_SANDBOX_INTEGRATION_ETCD_PORT=32379
CHEVALIER_SANDBOX_INTEGRATION_NATS_PORT=14222
CHEVALIER_SANDBOX_INTEGRATION_NATS_MONITOR_PORT=18222
CHEVALIER_SANDBOX_INTEGRATION_ETCD_ENDPOINTS=http://127.0.0.1:32379
CHEVALIER_SANDBOX_INTEGRATION_NATS_URL=nats://127.0.0.1:14222
CHEVALIER_SANDBOX_INTEGRATION_ARTIFACT_DIR=.integration-artifacts/local-dev
