{
  "name": "chevalier",
  "version": "0.0.0",
  "description": "TypeScript bindings for Chevalier — agents are just functions.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "napi": {
    "binaryName": "chevalier",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "native.js",
    "native.d.ts",
    "vfs-gateway-server.js",
    "vfs-gateway-server.d.ts",
    "*.node"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --js native.js --dts native.d.ts",
    "build:native:debug": "napi build --platform --js native.js --dts native.d.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build": "napi build --platform --release --js native.js --dts native.d.ts && tsc -p tsconfig.json",
    "test": "node --test --test-force-exit"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.0"
  },
  "peerDependencies": {
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.0"
  }
}
