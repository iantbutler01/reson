# @dive-file: Profile template for CI Linux KVM-backed real integration runs.
# @dive-rel: Loaded by scripts/integration/common.sh when --profile ci-linux-kvm is selected.
# @dive-rel: Aligns endpoint defaults with CI gate orchestration for verify-strict-real workflows.
RESON_SANDBOX_INTEGRATION_PROFILE=ci-linux-kvm
RESON_SANDBOX_INTEGRATION_PROJECT=reson-sandbox-int-ci-linux-kvm
RESON_SANDBOX_INTEGRATION_COMPOSE_FILE=deploy/integration/docker-compose.control-plane.yml
RESON_SANDBOX_INTEGRATION_CLUSTER_TOKEN=reson-sandbox-int-ci-linux-kvm
RESON_SANDBOX_INTEGRATION_ETCD_PORT=42379
RESON_SANDBOX_INTEGRATION_NATS_PORT=24222
RESON_SANDBOX_INTEGRATION_NATS_MONITOR_PORT=28222
RESON_SANDBOX_INTEGRATION_ETCD_ENDPOINTS=http://127.0.0.1:42379
RESON_SANDBOX_INTEGRATION_NATS_URL=nats://127.0.0.1:24222
RESON_SANDBOX_INTEGRATION_ARTIFACT_DIR=.integration-artifacts/ci-linux-kvm
