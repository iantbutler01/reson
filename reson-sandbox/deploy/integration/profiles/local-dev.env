# @dive-file: Profile template for local developer real integration harness runs.
# @dive-rel: Loaded by scripts/integration/common.sh when --profile local-dev is selected.
# @dive-rel: Targets deploy/integration/docker-compose.control-plane.yml with local host port mappings.
RESON_SANDBOX_INTEGRATION_PROFILE=local-dev
RESON_SANDBOX_INTEGRATION_PROJECT=reson-sandbox-int-local-dev
RESON_SANDBOX_INTEGRATION_COMPOSE_FILE=deploy/integration/docker-compose.control-plane.yml
RESON_SANDBOX_INTEGRATION_CLUSTER_TOKEN=reson-sandbox-int-local
RESON_SANDBOX_INTEGRATION_ETCD_PORT=32379
RESON_SANDBOX_INTEGRATION_NATS_PORT=14222
RESON_SANDBOX_INTEGRATION_NATS_MONITOR_PORT=18222
RESON_SANDBOX_INTEGRATION_ETCD_ENDPOINTS=http://127.0.0.1:32379
RESON_SANDBOX_INTEGRATION_NATS_URL=nats://127.0.0.1:14222
RESON_SANDBOX_INTEGRATION_ARTIFACT_DIR=.integration-artifacts/local-dev
